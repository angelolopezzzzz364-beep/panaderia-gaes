  .doc-card { transition: transform .3s ease, box-shadow .3s ease; }
  .doc-card:hover { transform: translateY(-4px); box-shadow: 0 16px 28px -10px rgba(62,107,71,0.22); }

  .tab-btn { transition: all .3s ease; }
  .tab-btn.active-tab {
    background-color: #3E6B47; color: #F2ECDD;
    box-shadow: 0 8px 18px -6px rgba(62,107,71,0.45);
  }
  .tab-panel { display: none; animation: fadeIn .5s ease; }
  .tab-panel.active-panel { display: grid; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px);} to { opacity:1; transform:translateY(0);} }

  .btn-gold { box-shadow: 0 8px 20px -8px rgba(198,154,68,0.55); }
  .btn-sena { box-shadow: 0 8px 20px -8px rgba(62,107,71,0.5); }

  /* Menú desplegable */
  #menu-panel { max-height: 0; overflow: hidden; transition: max-height .6s ease; }
  #menu-panel.open { max-height: 2600px; }
  #menu-toggle-icon { transition: transform .4s ease; }
  #menu-toggle-icon.rotated { transform: rotate(180deg); }

  a:focus-visible, button:focus-visible {
    outline: 2px solid #A67B2E; outline-offset: 3px; border-radius: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    .reveal, .product-card, .product-card .product-img, .doc-card, .tab-btn, #menu-panel { transition: none !important; }
  }
</style>
</head>

