<!-- ===================================================================
     GOOGLE FONTS
     - Playfair Display: serif elegante para el logotipo y titulares,
       inspirada en el trazo del logo real de "La Baguette Gourmet".
     - Cormorant Garamond (itálica): frases y acentos decorativos,
       recuerda el estilo caligráfico usado en el menú de tiza.
     - Poppins: texto de lectura general, cálido y muy legible.
     - JetBrains Mono: SOLO para metadatos de documentos en la
       sección de Entregables (nombre de archivo, tipo).
==================================================================== -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,600&family=Cormorant+Garamond:ital,wght@1,500;1,600&family=Poppins:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>
<script>
  // ===================================================================
  // Sistema de color derivado de la identidad REAL de la marca:
  // - "paper"  : tono kraft/crema, como el papel del afiche de portada.
  // - "chalk"  : negro pizarra, como el menú y las piezas publicitarias.
  // - "gold"   : dorado trigo, tomado del icono de espigas del logo.
  // - "ink"    : café oscuro, el mismo tono del texto "La Baguette".
  // - "sena"   : verde institucional, SOLO para las zonas académicas
  //              (GAES / Entregables), para separarlas del look comercial.
  // ===================================================================
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          paper:   '#EFE3C8',
          paper2:  '#E6D5AE',
          chalk:   '#1B1917',
          chalkline:'#F2ECDD',
          ink:     '#4A3324',
          ink2:    '#7A5B41',
          gold:    '#C69A44',
          goldd:   '#A67B2E',
          logotan: '#D8B98B',
          sena:    '#3E6B47',
          sena2:   '#E3EBDD',
        },
        fontFamily: {
          display: ['"Playfair Display"', 'serif'],
          script: ['"Cormorant Garamond"', 'serif'],
          body: ['"Poppins"', 'sans-serif'],
          mono: ['"JetBrains Mono"', 'monospace'],
        },
      }
    }
  }
</script>

<style>
  html { scroll-behavior: smooth; }
  body { background-color: #EFE3C8; }

  /* Textura de papel kraft, muy sutil */
  .paper-texture {
    background-image:
      radial-gradient(circle, #4A3324 0.5px, transparent 0.5px);
    background-size: 20px 20px;
    opacity: 0.05;
    position: absolute; inset: 0; pointer-events: none;
  }
  /* Textura de tiza sobre fondo negro (secciones de menú / academia) */
  .chalk-texture {
    background-image:
      radial-gradient(circle, #F2ECDD 0.6px, transparent 0.6px),
      radial-gradient(circle, #F2ECDD 0.4px, transparent 0.4px);
    background-size: 26px 26px, 14px 14px;
    background-position: 0 0, 8px 10px;
    opacity: 0.055;
    position: absolute; inset: 0; pointer-events: none;
  }

  /* Divisor punteado, igual al de la identidad gráfica real */
  .dashed-divider {
    display: flex; align-items: center; gap: 8px;
  }
  .dashed-divider::before, .dashed-divider::after {
    content: ''; flex: 1; height: 0;
    border-top: 1.5px dashed currentColor;
    opacity: .55;
  }

  /* Sello circular — usado como sello de calidad y como sello "revisado" */
  .sello {
    display: inline-flex; align-items: center; justify-content: center;
    border: 1.5px dashed currentColor;
    border-radius: 9999px;
    transform: rotate(-8deg);
